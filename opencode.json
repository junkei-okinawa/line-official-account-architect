{
  "$schema": "https://opencode.ai/config.schema.json",

  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://127.0.0.1:4321/v1"
      },
      "models": {
        "unsloth/qwen3.5-35b-a3b": {
          "name": "unsloth-qwen3.5-35b-a3b (local)"
        },
        "unsloth/gpt-oss-120b": {
          "name": "unsloth-gpt-oss-120b-q8 (local)"
        },
        "qwen3.5-122b-a10b": {
          "name": "mlx-qwen3.5-122b-a10b-4bit (local)"
        }
      }
    }
  },
  "agent": {

    "Prometheus": {
      "description": "Plan Builder",
      "model": "lmstudio:qwen3.5-122b-a10b",
      "temperature": 0.2,
      "maxTokens": 12000
    },

    "Atlas": {
      "description": "Plan Executor",
      "model": "lmstudio:unsloth/qwen3.5-35b-a3b",
      "temperature": 0.2,
      "maxTokens": 8192
    },

    "Hephaestus": {
      "description": "Deep Reasoning Agent",
      "model": "lmstudio:qwen3.5-122b-a10b",
      "temperature": 0.1,
      "maxTokens": 12000
    },

    "Sisyphus": {
      "description": "Ultraworker",
      "model": "lmstudio:unsloth/gpt-oss-120b",
      "temperature": 0.3,
      "maxTokens": 8192
    }

  }
}
